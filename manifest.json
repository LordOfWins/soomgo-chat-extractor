{
    "manifest_version": 3,
    "name": "숨고 채팅 추출기",
    "description": "숨고 채팅 추출(Alt+1) + 오래된 요청 자동 삭제(Alt+2)",
    "version": "1.2.0",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "commands": {
        "extract-chat": {
            "suggested_key": {
                "default": "Alt+1"
            },
            "description": "숨고 채팅 메시지 추출"
        },
        "delete-old-requests": {
            "suggested_key": {
                "default": "Alt+2"
            },
            "description": "숨고 오래된 요청 자동 삭제"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {}
}
