{
    "manifest_version": 3,
    "name": "숨고 채팅 추출기",
    "description": "숨고 채팅방 메시지를 전체 추출하여 클립보드에 복사합니다 (Alt+1)",
    "version": "1.1.0",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "commands": {
        "extract-chat": {
            "suggested_key": {
                "default": "Alt+1"
            },
            "description": "숨고 채팅 메시지 추출"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {}
}
